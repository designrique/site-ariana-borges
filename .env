# N8N Webhook URL para agendamento
VITE_N8N_WEBHOOK_URL=https://n8n.mapc.com.br/webhook

# Número WhatsApp Business (Meta Cloud API do projeto ariana-whatsapp)
# Formato: código país + DDD + número, sem +, espaços ou hífens
# Ex: 5511999999999
VITE_WHATSAPP_NUMBER=551153041409

# === AIOX Variables (added 2026-03-17) ===
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key at: https://exa.ai/
EXA_API_KEY=
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=
# Sentry (error tracking)
SENTRY_DSN=
# Railway (deployment)
RAILWAY_TOKEN=
# Vercel (deployment)
VERCEL_TOKEN=
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=2.2.0
