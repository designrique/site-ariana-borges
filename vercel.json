{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "routes": [
        {
            "src": "^/$",
            "has": [
                {
                    "type": "host",
                    "value": "encontrodeusas.arianaborges.com"
                }
            ],
            "dest": "/encontrodeusas.html"
        },
        {
            "src": "^/$",
            "has": [
                {
                    "type": "host",
                    "value": "clubelivromulhermaravilha.arianaborges.com"
                }
            ],
            "dest": "/clubelivromulhermaravilha.html"
        },
        {
            "src": "^/webhook-infinitepay$",
            "dest": "/api/webhook-infinitepay"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "^/(.*)$",
            "dest": "/index.html"
        }
    ]
}